{
  "name": "firmagob-client-examples",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "typecheck": "turbo run typecheck",
